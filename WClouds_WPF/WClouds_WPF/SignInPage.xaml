<Page x:Class="WClouds_WPF.SignInPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WClouds_WPF"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="SignInPage">

    <Grid>
        <StackPanel x:Name="SignPagePanel" VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBox x:Name="emailTextBox" Text="Email" FontSize="30" Width="200" Height="40" Margin="10" Foreground="Black" Background="Gray"></TextBox>
            <TextBox x:Name="passwordTextBox" Text="Password" FontSize="30" Width="200" Height="40" Margin="10" Foreground="Black" Background="Gray"></TextBox>
        </StackPanel>
        <Button x:Name="SignInButton"  Content="GO!" HorizontalAlignment="Center" Background="LawnGreen" VerticalAlignment="Top" FontSize="20" Width="100" Height="30" Margin="0,350,0,0" Click="SignInButton_Click"></Button>
        <Frame Name="MainFrame" NavigationUIVisibility="Hidden"/>
    </Grid>
</Page>
