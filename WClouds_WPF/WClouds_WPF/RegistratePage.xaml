<Page x:Class="WClouds_WPF.RegistratePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:WClouds_WPF"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="RegistratePage">

    <Page.Resources>

        <Style x:Key="InputBox" TargetType="TextBox">
            <Setter Property="Background"               Value="#12121E"/>
            <Setter Property="Foreground"               Value="#E0E0F0"/>
            <Setter Property="CaretBrush"               Value="#7C6AF7"/>
            <Setter Property="BorderBrush"              Value="#3A3A5A"/>
            <Setter Property="BorderThickness"          Value="1"/>
            <Setter Property="FontFamily"               Value="Segoe UI"/>
            <Setter Property="FontSize"                 Value="13"/>
            <Setter Property="Height"                   Value="36"/>
            <Setter Property="Padding"                  Value="8,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#7C6AF7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InputPassword" TargetType="PasswordBox">
            <Setter Property="Background"               Value="#12121E"/>
            <Setter Property="Foreground"               Value="#E0E0F0"/>
            <Setter Property="CaretBrush"               Value="#7C6AF7"/>
            <Setter Property="BorderBrush"              Value="#3A3A5A"/>
            <Setter Property="BorderThickness"          Value="1"/>
            <Setter Property="FontFamily"               Value="Segoe UI"/>
            <Setter Property="FontSize"                 Value="13"/>
            <Setter Property="Height"                   Value="36"/>
            <Setter Property="Padding"                  Value="8,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#7C6AF7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background"      Value="#7C6AF7"/>
            <Setter Property="Foreground"      Value="#E0E0F0"/>
            <Setter Property="FontFamily"      Value="Segoe UI Semibold"/>
            <Setter Property="FontSize"        Value="14"/>
            <Setter Property="Height"          Value="40"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#6557D4"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#4A3FB8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background"      Value="#2A2A3E"/>
            <Setter Property="Foreground"      Value="#E0E0F0"/>
            <Setter Property="FontFamily"      Value="Segoe UI Semibold"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Height"          Value="36"/>
            <Setter Property="BorderBrush"     Value="#7C6AF7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#7C6AF7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Page.Resources>

    <Grid Background="#1E1E2E">

        <!-- Header -->
        <Border VerticalAlignment="Top" Height="50"
                Background="#2A2A3E"
                BorderBrush="#7C6AF7" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0">
                <TextBlock Text="☁" Foreground="#7C6AF7" FontSize="20" VerticalAlignment="Center"/>
                <TextBlock Text="Registrieren" Foreground="#E0E0F0"
                           FontFamily="Segoe UI Semibold" FontSize="18"
                           Margin="10,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Card -->
        <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                Background="#2A2A3E" CornerRadius="14" Padding="40,32"
                BorderBrush="#7C6AF7" BorderThickness="1" MinWidth="340">

            <StackPanel x:Name="RegisterPanel">

                <TextBlock Text="✨ Neues Konto" Foreground="#E0E0F0"
                           FontFamily="Segoe UI Semibold" FontSize="18"
                           HorizontalAlignment="Center" Margin="0,0,0,20"/>

                <!-- Email -->
                <TextBlock Text="E-Mail" Foreground="#7A7A9A" FontSize="11"
                           FontFamily="Segoe UI" Margin="0,0,0,4"/>
                <Grid Width="260" Height="36" Margin="0,0,0,0">
                    <TextBox x:Name="EmailBox" Style="{StaticResource InputBox}"/>
                    <TextBlock Text="deine@email.com" Foreground="#4A4A6A"
                               FontFamily="Segoe UI" FontSize="13"
                               Margin="10,0,0,0" VerticalAlignment="Center"
                               IsHitTestVisible="False">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Text, ElementName=EmailBox}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>

                <!-- Passwort -->
                <TextBlock Text="Passwort" Foreground="#7A7A9A" FontSize="11"
                           FontFamily="Segoe UI" Margin="0,12,0,4"/>
                <Grid Width="260">
                    <PasswordBox x:Name="PasswordBox"
                                 Style="{StaticResource InputPassword}"
                                 PasswordChanged="PasswordBox_PasswordChanged"/>
                    <TextBlock x:Name="PasswordPlaceholder" Text="Passwort eingeben"
                               Foreground="#4A4A6A" FontFamily="Segoe UI" FontSize="13"
                               Margin="10,0,0,0" VerticalAlignment="Center"
                               IsHitTestVisible="False"/>
                </Grid>

                <!-- Key-Datei -->
                <TextBlock Text="Key-Datei" Foreground="#7A7A9A" FontSize="11"
                           FontFamily="Segoe UI" Margin="0,12,0,4"/>
                <StackPanel Orientation="Horizontal" Width="260">
                    <Grid Width="186" Height="36">
                        <TextBox x:Name="KeyFilePathBox" IsReadOnly="True"
                                 Style="{StaticResource InputBox}"/>
                        <TextBlock Text="Keine Datei gewählt" Foreground="#4A4A6A"
                                   FontFamily="Segoe UI" FontSize="13"
                                   Margin="10,0,0,0" VerticalAlignment="Center"
                                   IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=KeyFilePathBox}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                    <Button Content="📂" Style="{StaticResource SecondaryButton}"
                            Width="68" Margin="6,0,0,0"
                            Click="SelectKeyFile_Click"/>
                </StackPanel>

                <TextBlock x:Name="KeyPreviewText" Foreground="#7A7A9A"
                           FontSize="11" FontFamily="Segoe UI"
                           Margin="0,6,0,0" TextWrapping="Wrap" MaxWidth="260"/>

                <!-- Register Button -->
                <Button x:Name="RegisterButton" Content="Registrieren ✨"
                        Style="{StaticResource PrimaryButton}"
                        Width="260" Margin="0,24,0,0"
                        Click="RegisterButton_Click"/>

            </StackPanel>
        </Border>

        <Frame Name="MainFrame" NavigationUIVisibility="Hidden"/>
    </Grid>
</Page>