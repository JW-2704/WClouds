<Page x:Class="WClouds_WPF.RegistratePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WClouds_WPF"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="RegistratePage">

    <Grid>
        <StackPanel x:Name="RegisterPanel" VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBox x:Name="EmailBox" Foreground="Gray" Text="Email" Margin="0,5"/>
            <PasswordBox x:Name="PasswordBox"/>

            <StackPanel Orientation="Horizontal" Margin="0,5">
                <TextBox x:Name="KeyFilePathBox" IsReadOnly="True" Width="250"/>
                <Button Content="Datei wählen" Click="SelectKeyFile_Click" Margin="5,0"/>
            </StackPanel>

            <TextBlock x:Name="KeyPreviewText" Foreground="Gray" FontSize="11" Margin="0,3"/>
        </StackPanel>
        <Button x:Name="RegisterButton"  Content="GO!" HorizontalAlignment="Center" Background="LawnGreen" VerticalAlignment="Top" FontSize="20" Width="100" Height="30" Margin="0,350,0,0" Click="SignInButton_Click"></Button>
        <Frame Name="MainFrame" NavigationUIVisibility="Hidden"/>
    </Grid>
</Page>
