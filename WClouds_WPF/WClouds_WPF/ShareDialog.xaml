<Window x:Class="WClouds_WPF.ShareDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Datei teilen"
        Width="380" Height="260"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#1E1E2E"
        Foreground="#E0E0F0"
        FontFamily="Segoe UI">

    <Window.Resources>
        <SolidColorBrush x:Key="AccentBrush" Color="#7C6AF7"/>
        <SolidColorBrush x:Key="PanelBrush"  Color="#2A2A3E"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#E0E0F0"/>
        <SolidColorBrush x:Key="TextMuted"   Color="#7A7A9A"/>

        <Style x:Key="DialogBtn" TargetType="Button">
            <Setter Property="Height"          Value="32"/>
            <Setter Property="Padding"         Value="16,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Foreground"      Value="#E0E0F0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.7"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Background" Value="#22223A"/>
                                <Setter Property="Foreground" Value="#4A4A6A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#E0E0F0"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize"   Value="13"/>
            <Setter Property="Cursor"     Value="Hand"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background"       Value="#33334A"/>
            <Setter Property="Foreground"       Value="#E0E0F0"/>
            <Setter Property="BorderBrush"      Value="#7C6AF7"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="Padding"          Value="8,6"/>
            <Setter Property="FontFamily"       Value="Segoe UI"/>
            <Setter Property="FontSize"         Value="13"/>
            <Setter Property="CaretBrush"       Value="#E0E0F0"/>
        </Style>
    </Window.Resources>

    <Border Padding="24">
        <StackPanel>
            <!-- Title -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                <TextBlock Text="👥" FontSize="18" Margin="0,0,8,0" VerticalAlignment="Center"/>
                <TextBlock Text="Datei teilen" FontSize="16" FontFamily="Segoe UI Semibold"
                           Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Email input -->
            <TextBlock Text="E-Mail des Empfängers"
                       Foreground="{StaticResource TextMuted}"
                       FontSize="11" Margin="0,0,0,4"/>
            <TextBox x:Name="EmailBox"
                     Height="34"
                     VerticalContentAlignment="Center"/>

            <!-- Permissions -->
            <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
                <CheckBox x:Name="CanReadBox"   Content="Lesen"      IsChecked="True" Margin="0,0,20,0"/>
                <CheckBox x:Name="CanWriteBox"  Content="Schreiben"  IsChecked="False"/>
            </StackPanel>

            <!-- Error text -->
            <TextBlock x:Name="ErrorText"
                       Foreground="#F47C7C"
                       FontSize="11"
                       Margin="0,8,0,0"
                       Visibility="Collapsed"
                       TextWrapping="Wrap"/>

            <!-- Buttons -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button Content="Abbrechen"
                        Style="{StaticResource DialogBtn}"
                        Background="#33334A"
                        Margin="0,0,8,0"
                        Click="Cancel_Click"/>
                <Button x:Name="ShareBtn"
                        Content="Teilen"
                        Style="{StaticResource DialogBtn}"
                        Background="#7C6AF7"
                        Click="Share_Click"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
