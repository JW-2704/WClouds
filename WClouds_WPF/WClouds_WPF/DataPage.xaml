<Page x:Class="WClouds_WPF.DataPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:WClouds_WPF"
      mc:Ignorable="d"
      d:DesignHeight="450" d:DesignWidth="800"
      Title="DataPage">

    <Page.Resources>
        <SolidColorBrush x:Key="BgBrush"     Color="#1E1E2E"/>
        <SolidColorBrush x:Key="PanelBrush"  Color="#2A2A3E"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#7C6AF7"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#E0E0F0"/>
        <SolidColorBrush x:Key="TextMuted"   Color="#7A7A9A"/>
        <SolidColorBrush x:Key="HoverBrush"  Color="#33334A"/>
        <SolidColorBrush x:Key="GreenBrush"  Color="#4CAF7D"/>

        <!-- Toolbar Button -->
        <Style x:Key="ToolbarBtn" TargetType="Button">
            <Setter Property="Background"      Value="#33334A"/>
            <Setter Property="Foreground"      Value="#E0E0F0"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Height"          Value="30"/>
            <Setter Property="Padding"         Value="12,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#7C6AF7"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#4A3FB8"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Background" Value="#22223A"/>
                                <Setter Property="Foreground" Value="#4A4A6A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Upload Button (green accent) -->
        <Style x:Key="UploadBtn" TargetType="Button" BasedOn="{StaticResource ToolbarBtn}">
            <Setter Property="Background" Value="#3A5A4A"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#4CAF7D"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2E7D55"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Background" Value="#22223A"/>
                                <Setter Property="Foreground" Value="#4A4A6A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- TreeViewItem Style -->
        <Style TargetType="TreeViewItem">
            <Setter Property="Foreground"      Value="{StaticResource TextPrimary}"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Padding"         Value="4,3"/>
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TreeViewItem">
                        <StackPanel>
                            <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                    BorderThickness="0" CornerRadius="6" Padding="4,2" Margin="0,1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition/>
                                    </Grid.ColumnDefinitions>
                                    <ToggleButton x:Name="Expander"
                                                  Grid.Column="0"
                                                  IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                                  Visibility="Collapsed"
                                                  Focusable="False"
                                                  Width="16" Height="16">
                                        <ToggleButton.Style>
                                            <Style TargetType="ToggleButton">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="ToggleButton">
                                                            <TextBlock x:Name="Arrow" Text="▶"
                                                                       Foreground="{StaticResource AccentBrush}"
                                                                       FontSize="9" VerticalAlignment="Center"
                                                                       HorizontalAlignment="Center"/>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsChecked" Value="True">
                                                                    <Setter TargetName="Arrow" Property="Text" Value="▼"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </ToggleButton.Style>
                                    </ToggleButton>
                                    <ContentPresenter Grid.Column="1" ContentSource="Header"
                                                      VerticalAlignment="Center" Margin="4,0,0,0"/>
                                </Grid>
                            </Border>
                            <ItemsPresenter x:Name="ItemsHost" Margin="20,0,0,0"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="HasItems" Value="True">
                                <Setter TargetName="Expander" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsExpanded" Value="False">
                                <Setter TargetName="ItemsHost" Property="Visibility" Value="Collapsed"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource HoverBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TreeView">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto"/>
        </Style>

        <!-- ListView (Datei-Detailliste, rechte Spalte) -->
        <Style TargetType="ListView">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style TargetType="ListViewItem">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="{StaticResource TextPrimary}"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Padding"         Value="4,4"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource HoverBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="GridViewColumnHeader">
            <Setter Property="Background"      Value="#242436"/>
            <Setter Property="Foreground"      Value="{StaticResource TextMuted}"/>
            <Setter Property="FontFamily"      Value="Segoe UI Semibold"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="Padding"         Value="6,4"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush"     Value="{StaticResource AccentBrush}"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
        </Style>
    </Page.Resources>

    <Grid Background="{StaticResource BgBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="44"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource AccentBrush}" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0">
                <TextBlock Text="☁" Foreground="{StaticResource AccentBrush}"
                           FontSize="18" VerticalAlignment="Center"/>
                <TextBlock Text="Meine Dateien" Foreground="{StaticResource TextPrimary}"
                           FontFamily="Segoe UI Semibold" FontSize="16"
                           Margin="10,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Toolbar -->
        <Border Grid.Row="1" Background="#242436" Padding="12,0">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Button x:Name="UploadFileBtn"
                        Style="{StaticResource UploadBtn}"
                        Click="UploadFile_Click"
                        Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⬆" FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Datei hochladen" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button x:Name="UploadFolderBtn"
        Style="{StaticResource UploadBtn}"
        Click="UploadFolder_Click"
        Margin="8,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📁" FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Ordner hochladen" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button x:Name="ShareBtn"
        Style="{StaticResource ToolbarBtn}"
        Click="ShareBtn_Click"
        Margin="8,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="👥" FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Share" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button x:Name="RefreshBtn"
                        Style="{StaticResource ToolbarBtn}"
                        Click="Refresh_Click"
                        Margin="8,0,8,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="↻" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Aktualisieren" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button x:Name="DownloadBtn"
                        Style="{StaticResource ToolbarBtn}"
                        Click="DownloadFile_Click"
                        IsEnabled="False">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⬇" FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Herunterladen" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button x:Name="OverwriteBtn"
                        Style="{StaticResource ToolbarBtn}"
                        Click="OverwriteFile_Click"
                        IsEnabled="False"
                        Margin="8,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🔁" FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Überschreiben" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button x:Name="HistoryBtn"
                        Style="{StaticResource ToolbarBtn}"
                        Click="HistoryBtn_Click"
                        IsEnabled="False"
                        Margin="8,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🕐" FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Verlauf" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button x:Name="DeleteBtn"
                        Style="{StaticResource ToolbarBtn}"
                        Click="DeleteEntry_Click"
                        IsEnabled="False"
                        Margin="8,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🗑" FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Löschen" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button x:Name="LogoutBtn"
        Style="{StaticResource ToolbarBtn}"
        Click="Logout_Click"
        Margin="8,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⇦" FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Abmelden" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>

        <!-- Ordnerbaum (links) + Datei-Detailliste (rechts) -->
        <Grid Grid.Row="2" Margin="12,8,12,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{StaticResource PanelBrush}"
                    CornerRadius="10" Padding="8">
                <TreeView x:Name="FolderTree"
                          SelectedItemChanged="FolderTree_SelectedItemChanged"/>
            </Border>

            <Border Grid.Column="2" Background="{StaticResource PanelBrush}"
                    CornerRadius="10" Padding="8">
                <ListView x:Name="FileList"
                          SelectionMode="Single"
                          SelectionChanged="FileList_SelectionChanged"
                          MouseDoubleClick="FileList_MouseDoubleClick">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Name" Width="280">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Icon}" Margin="0,0,6,0"/>
                                            <TextBlock Text="{Binding Name}"/>
                                            <TextBlock Text=" 🔒" Visibility="{Binding LockVisibility}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Größe" Width="100" DisplayMemberBinding="{Binding SizeDisplay}"/>
                            <GridViewColumn Header="Geändert am" Width="170" DisplayMemberBinding="{Binding ChangedDisplay}"/>
                            <GridViewColumn Header="Eigentümer" Width="90" DisplayMemberBinding="{Binding Owner}"/>
                            <GridViewColumn Header="Geändert von" Width="100" DisplayMemberBinding="{Binding ChangedUser}"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </Border>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="3" Background="#242436" Padding="16,6">
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="StatusText"
                           Text="Bereit."
                           Foreground="{StaticResource TextMuted}"
                           FontFamily="Segoe UI" FontSize="11"/>
            </StackPanel>
        </Border>
        <Frame Name="MainFrame" NavigationUIVisibility="Hidden"/>
    </Grid>
</Page>